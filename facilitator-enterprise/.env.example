HOST=0.0.0.0
PORT=8080

# --- Upstream chain/scheme config (JSON) ---
# CONFIG=/app/config.json

# --- Enterprise config (TOML, optional — defaults to permissive) ---
# CONFIG_FILE=config.toml

# --- API Authentication ---
# Comma-separated list of valid API keys. If unset, auth is disabled.
# API_KEYS=key1,key2,key3

# Admin key for /admin/* endpoints. If unset, admin endpoints return 401.
# ADMIN_API_KEY=my-admin-secret

# --- OpenTelemetry (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io:443
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your_api_key
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# --- Hook contract addresses (used in hooks.toml via ${ENV_VAR}) ---
# HOOK_NOTIFY_BASE_SEPOLIA_CONTRACT=0x...
# NOTIFY_RECIPIENT_BASE_SEPOLIA=0x...
